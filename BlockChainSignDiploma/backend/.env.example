# ==================== DATABASE ====================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/diploma_db

# ==================== JWT ====================
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== FABRIC ====================
# Fabric network paths (adjust to your setup)
FABRIC_NETWORK_PATH=../../fabric-samples/test-network
FABRIC_MSP_ID=Org1MSP
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=diploma

# Fabric credentials paths
FABRIC_CERT_PATH=../../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/Admin@org1.example.com/msp/signcerts/cert.pem
FABRIC_KEY_PATH=../../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/msp/keystore/priv_sk
FABRIC_TLS_CERT_PATH=../../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt

# Fabric peer endpoint
FABRIC_PEER_ENDPOINT=localhost:7051

# ==================== APPLICATION ====================
APP_NAME=Blockchain Diploma Management System
APP_VERSION=2.0.0
DEBUG=True

# CORS
CORS_ORIGINS=*

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== PDF GENERATION ====================
PDF_TEMPLATE_PATH=app/Services/PDFService/templates/diploma_template.html
PDF_OUTPUT_DIR=outputs/diplomas

# ==================== VERIFICATION ====================
VERIFY_BASE_URL=https://verify.edu.vn
